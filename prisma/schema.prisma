generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String?
  password   String?
  avatar     String?
  bio        String?
  membership      String    @default("free")  // free|pro
  membershipId    String?   @unique            // 会员号，如 PRO-20260527-001
  membershipExpiresAt DateTime?  // 会员到期时间，null为永久
  apiKey           String?   // 用户自己的 AI API Key
  apiProvider       String?  @default("deepseek")  // deepseek|openai|anthropic
  dashscopeApiKey   String?   // 用户自己的 DashScope 通义万相 API Key
  createdAt  DateTime  @default(now())
  contents   Content[]
  mindmaps   MindMap[]
  stories    Story[]
  novels        Novel[]
  videoProjects VideoProject[]
  notes        Note[]
  simulations  Simulation[]
  reports      Report[]
  membershipCode MembershipCode? @relation("CodeUser")
  creationDrafts CreationDraft?
}

model MembershipCode {
  id          String    @id @default(cuid())
  codeHash    String    @unique    // SHA-256 hash of the code
  tier        String    @default("pro")  // pro
  duration    Int?                 // days, null = permanent
  usedBy      String?   @unique    // user ID who used it
  usedAt      DateTime?            // when it was used
  expiresAt   DateTime?            // code expiration date (before use)
  createdBy   String               // admin who created it
  createdAt   DateTime @default(now())
  user        User?    @relation("CodeUser", fields: [usedBy], references: [id])
}

model Novel {
  id              String    @id @default(cuid())
  title           String
  genre           String?   // xuanhuan/xianxia/urban/scifi/romance/mystery/history/game
  synopsis        String?   // 一句话简介
  description     String?   // 详细描述
  targetWordCount Int?      // 目标总字数
  dailyWordTarget Int       @default(1000)  // 每日字数目标
  status          String    @default("planning")  // planning|writing|completed|paused
  coverColor      String?   // 封面主题色
  chapters        Chapter[]
  worldSetting    WorldSetting?
  characters      Character[]
  codexEntries    CodexEntry[]
  outlines        Outline[]
  writingLogs     WritingLog[]
  truthFiles      TruthFile[]
  editorialReviews EditorialReview[]
  emotionalCurves  EmotionalCurve[]
  creationDrafts   CreationDraft[]
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model WritingLog {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date  // 写作日期
  wordCount Int      // 当日新增字数
  createdAt DateTime @default(now())
  @@unique([novelId, date])
}

model WorldSetting {
  id          String   @id @default(cuid())
  novelId     String   @unique
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  worldType   String?  // cultivation/cyberpunk/cthulhu/wasteland/modern/other
  scale       String?  // single_city/multi_region/continent/multi_realm
  powerSystem String?  // 力量体系描述（markdown）
  geography   String?  // 地理架构
  factions    String?  // 势力格局
  rules       String?  // 世界规则/铁律
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Character {
  id            String   @id @default(cuid())
  novelId       String
  novel         Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  name          String
  role          String   @default("supporting")  // protagonist|antagonist|supporting|love_interest|mentor
  tagline       String?  // 称号/外号
  appearance    String?  // 外貌
  personality   String?  // 性格（显性+隐性）
  desire        String?  // 欲望/外目标
  flaw          String?  // 缺陷
  wound         String?  // 创伤
  need          String?  // 内在需求
  change        String?  // 成长弧线
  goldenFinger  String?  // 金手指
  relationships String?  // 人际关系（JSON）
  sortOrder     Int      @default(0)

  // ===== 角色 Agent 字段 =====
  // 大五人格向量（0-10，null 表示未设定）
  openness          Float?   // 开放性：好奇心、想象力
  conscientiousness Float?   // 尽责性：自律、计划性
  extraversion      Float?   // 外向性：社交能量
  agreeableness     Float?   // 宜人性：合作、同理心
  neuroticism       Float?   // 神经质：情绪波动性

  // 语言指纹（JSON）
  languageFingerprint String? @default("{}")
  // 结构: { avgSentenceLength, vocabComplexity, dialectMarkers, forbiddenWords,
  //         signaturePhrases, punctuationStyle, narrativeVoice }

  // 当前状态（JSON，随章节更新）
  agentState        String? @default("{}")
  // 结构: { location, emotionalState, primaryMotivation, activeFear, energyLevel }

  // 行为约束（JSON）
  behaviorConstraints String? @default("{}")
  // 结构: { hardLimits, softLimits, triggers, speechPatterns: { formality, verbosity, humor } }

  // 关系
  memories          CharacterMemory[]
  knowledge         CharacterKnowledge[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CharacterMemory {
  id          String   @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  chapterId   String?
  type        String   @default("experience") // experience|observation|emotion|knowledge
  content     String
  importance  Float    @default(0.5) // 0-1
  emotionTag  String?  // 情感标签
  tags        String   @default("[]") // JSON array
  createdAt   DateTime @default(now())

  @@index([characterId, type])
  @@index([characterId, importance(sort: Desc)])
}

model CharacterKnowledge {
  id          String   @id @default(cuid())
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type        String   // event|secret|relationship|world_fact
  content     String
  source      String?  // 从哪里知道的
  acquiredAt  String?  // 第几章获得
  isSecret    Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([characterId, type])
}

model CodexEntry {
  id          String   @id @default(cuid())
  novelId     String
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  type        String   @default("custom")  // location|faction|event|item|creature|world_rule|custom
  name        String
  summary     String?  // Short summary for AI context injection
  body        String?  // Detailed description (markdown)
  keywords    String   @default("[]")  // JSON array of trigger keywords
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Outline {
  id        String    @id @default(cuid())
  novelId   String
  novel     Novel     @relation(fields: [novelId], references: [id], onDelete: Cascade)
  title     String    // 卷/篇章标题
  type      String    @default("volume")  // volume|chapter
  parentId  String?   // 父节点
  parent    Outline?  @relation("OutlineTree", fields: [parentId], references: [id])
  children  Outline[] @relation("OutlineTree")
  nodes     String?   // CBN/CPNs/CEN JSON
  summary   String?   // 本章摘要
  wordTarget Int?     // 目标字数
  sortOrder Int       @default(0)
  chapters  Chapter[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Chapter {
  id           String   @id @default(cuid())
  title        String
  body         String   @default("")
  order        Int
  wordCount    Int      @default(0)
  factSnapshot String?  // JSON — { newFacts, stateChanges, openHooks, characterMoments }
  novelId      String
  novel        Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  outlineId    String?
  outline      Outline? @relation(fields: [outlineId], references: [id])
  editorialReviews EditorialReview[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TruthFile {
  id        String   @id @default(cuid())
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  type      String   // current_state|particle_ledger|pending_hooks|chapter_summaries|subplot_board|emotional_arcs|character_matrix
  content   String   @default("")  // Markdown 内容
  version   Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([novelId, type])
}

model Content {
  id          String   @id @default(cuid())
  title       String
  body        String   @default("")
  platform    String   @default("wechat")
  contentType String   @default("article")
  wordCount   Int      @default(0)
  status      String   @default("draft")
  isPublic    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MindMap {
  id        String   @id @default(cuid())
  title     String
  markdown  String   @default("")
  nodeCount Int      @default(0)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Story {
  id              String   @id @default(cuid())
  title           String
  content         String   @default("")
  wordCount       Int      @default(0)
  targetWordCount Int      @default(3000)
  promptId        String?
  status          String   @default("draft")
  isPublic        Boolean  @default(false)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model VideoProject {
  id        String     @id @default(cuid())
  title     String
  topic     String
  platform  String     @default("douyin")
  style     String?
  script    String?
  status    String     @default("draft")
  bgmPath   String?
  outputUrl String?
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  clips     VideoClip[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model VideoClip {
  id           String       @id @default(cuid())
  projectId    String
  project      VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  order        Int
  scriptText   String
  visualPrompt String
  duration     Float        @default(5.0)
  clipUrl      String?
  voiceUrl     String?
  status       String       @default("pending")
  createdAt    DateTime     @default(now())
}

model Note {
  id        String     @id @default(cuid())
  title     String
  body      String     @default("")
  tags      String     @default("[]")
  links     NoteLink[] @relation("From")
  backlinks NoteLink[] @relation("To")
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model NoteLink {
  id     String @id @default(cuid())
  fromId String
  toId   String
  fromNote Note @relation("From", fields: [fromId], references: [id], onDelete: Cascade)
  toNote   Note @relation("To", fields: [toId], references: [id], onDelete: Cascade)
  @@unique([fromId, toId])
}

model Simulation {
  id           String   @id @default(cuid())
  topic        String
  seedMaterial String?  @default("")
  agentCount   Int      @default(10)
  rounds       Int      @default(5)
  result       String?  // JSON blob — { summary, report, rounds, agents }
  status       String   @default("running")  // running|completed|failed
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  targetType  String   // novel|content|video|note|simulation
  targetId    String
  reason      String   // illegal|spam|abuse|other
  description String?
  status      String   @default("pending")  // pending|reviewed|resolved|dismissed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EditorialReview {
  id          String   @id @default(cuid())
  novelId     String
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId   String
  chapter     Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  // 5 个角色的独立评审
  authorReview    String?  @default("{}")
  editorReview    String?  @default("{}")
  chiefReview     String?  @default("{}")
  readerReview    String?  @default("{}")
  continuityReview String? @default("{}")

  // 辩论记录
  debateLog       String?  @default("[]")

  // 投票结果
  votes           String?  @default("{}")
  finalDecision   String?
  chiefRuling     String?

  createdAt       DateTime @default(now())

  @@unique([novelId, chapterId])
}

model EmotionalCurve {
  id          String   @id @default(cuid())
  novelId     String
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  chapterId   String?

  // 目标曲线
  targetCurve String

  // 实际曲线
  actualCurve String?

  // 叙事手段建议
  narrativeTechniques String? @default("[]")

  // 验证结果
  validationScore     Float?
  validationDetails   String?

  createdAt   DateTime @default(now())
}

model CreationDraft {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId     String?
  novel       Novel?   @relation(fields: [novelId], references: [id])
  messages    String   @default("[]")  // JSON array of messages
  wizardData  String?  // JSON wizard data
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
